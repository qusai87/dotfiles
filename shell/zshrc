# Path to your oh-my-zsh configuration.
export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$ZSH/custom"

# Base PATH
PATH="/usr/local/bin:/usr/bin:/bin:/usr/local/games:/usr/games:$PATH"

# Directories to be prepended to $PATH
typeset -a dirs_to_prepend=(
  "/usr/bin"
  "/usr/local/sbin"
  "/usr/local/git/bin"
  "/usr/local/"
  "/usr/local/mysql/bin"
  "/sw/bin"
  "$HOME/dotfiles/bin"
  "$HOME/bin"
  "$HOME/.rvm/bin"
)

if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
  dirs_to_prepend+=( "$(brew --prefix)/libexec/gnubin" ) # Add brew-installed GNU core utilities bin
  dirs_to_prepend+=( "$(brew --prefix)/share/npm/bin" )  # Add npm-installed package bins
fi

for dir in "${dirs_to_prepend[@]}"; do
  if [[ -d $dir ]]; then
    PATH="${dir}:$PATH"
  fi
done

unset dirs_to_prepend

export PATH

# Set name of the theme to load.
ZSH_THEME="powerlevel10k/powerlevel10k"

# Which plugins would you like to load? (plugins can be found in ~/.oh-my-zsh/plugins/*)
# Custom plugins may be added to ~/.oh-my-zsh/custom/plugins/
plugins=(
  git
  fabric
  brew
  node
  npm
  history
  git-flow
  vagrant
  zsh-autosuggestions
  zsh-syntax-highlighting
)

# Source Oh My Zsh
source "$ZSH/oh-my-zsh.sh"

# User configuration
# Load the shell dotfiles
for file in $HOME/.{shell_exports,shell_aliases,shell_functions,shell_config}; do
  [ -r "$file" ] && [ -f "$file" ] && source "$file";
done;
unset file;

# Enable npm tab completion if npm exists
if command -v npm >/dev/null 2>&1; then
  . <(npm completion)
fi

# Optional: show a fortune with ponysay (commented out to avoid slowing startup)
# fortune | ponysay

# Ensure Homebrew environment is available when installed
if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
fi

# Enable Powerlevel10k instant prompt.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \
. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \
. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Aliases
alias ll='ls -l'
alias zshconfig="code ~/.zshrc"
alias ohmyzsh="code ~/.oh-my-zsh"
alias reload="source ~/.zshrc"
alias ls='ls --color=auto'
alias grep='grep --color=auto'


## For Git
alias st='git status'
alias logs='git log --oneline --graph --decorate --all'
alias pull='git pull --rebase'
alias push='git push --force-with-lease'

alias ollama-claude="ollama launch claude --model  minimax-m3:cloud"

[[ -d "$HOME/Projects" ]] && cd "$HOME/Projects"

[[ -f "$HOME/myenv/bin/activate" ]] && source "$HOME/myenv/bin/activate"

if [[ -f "$HOME/.dircolors" ]]; then
  eval "$(dircolors -b "$HOME/.dircolors")"
fi


